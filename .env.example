# --- Backend Settings ---
# Database (SQLite — no server needed, stored as a local file)
DATABASE_URL=sqlite+aiosqlite:///data/dexter.db

# Qdrant (embedded mode — stored as a local directory)
QDRANT_PATH=data/qdrant
QDRANT_COLLECTION_NAME=dexter_memory

# LLM Configuration (OpenAI-compatible API)
DEFAULT_LLM_PROVIDER=gemini
LLM_API_KEY=your-google-ai-or-openai-key
LLM_MODEL=gemini-2.5-flash
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# Security (Run 'openssl rand -hex 32' to generate a new key)
SECRET_KEY=generate-a-random-hex-string
MAX_PROMPT_CHARS=12000
MAX_TOOL_INPUT_CHARS=6000

# Agent file storage (where the agent can read/write files)
AGENT_FILES_ROOT=C:/Users/YourName/dexter_agent_files

# --- Optional External Services ---
SERPAPI_KEY=your-serpapi-key
SENTRY_DSN=

# Email (SMTP/IMAP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@localhost
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=

# Google Calendar
GOOGLE_CALENDAR_ACCESS_TOKEN=
GOOGLE_CALENDAR_ID=primary

# --- Desktop App Settings ---
WAKE_WORD=hi dexter
WAKE_WORD_SENSITIVITY=0.5
HOTKEY=<ctrl>+<alt>+d
ENABLE_HOTKEY=true

# Conversational Mode (follow-up window)
ENABLE_CONVERSATION_MODE=true
CONVERSATION_TIMEOUT=8

# Audio Feedback
ENABLE_EARCONS=true
EARCON_VOLUME=0.3

# Visual Feedback (Glow colors)
GLOW_COLOR_LISTENING=#2196F3
GLOW_COLOR_THINKING=#FF9800
GLOW_COLOR_SPEAKING=#4CAF50
GLOW_COLOR_CONVERSATION=#9C27B0

# Text-to-Speech
TTS_VOICE=en-US-ChristopherNeural
TTS_RATE=+0%
AUTO_SPEAK_RESPONSES=true

# Environment
ENVIRONMENT=dev
CORS_ORIGINS=*
