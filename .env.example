# Docker Compose Postgres (also used by DATABASE_URL when running via compose)
POSTGRES_PASSWORD=svet

# Database
DATABASE_URL=postgresql+asyncpg://svet:svet@localhost:5432/svet

# Redis (broker + cache + rate limiting)
REDIS_URL=redis://localhost:6379/0

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_NAME=svet_memory

# -----------------------------------------------------------------------------
# LLM routing (DEFAULT_LLM_PROVIDER=auto)
# - Short / text-only tasks (estimated context <= LLM_LONG_CONTEXT_THRESHOLD_TOKENS)
#   use Cerebras (fast OpenAI-compatible API).
# - Vision (image_url attachments, multimodal content, or image-like URLs in text)
#   OR estimated context *strictly above* the threshold → Google AI Studio Gemini 2.5 Flash
#   via the Gemini OpenAI-compatible endpoint.
# You can also force: cerebras | gemini | anthropic | openai
# -----------------------------------------------------------------------------
DEFAULT_LLM_PROVIDER=auto

# Google AI Studio — Gemini (OpenAI-compatible base URL; model default gemini-2.5-flash)
GOOGLE_AI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# Cerebras Inference — small / fast steps (OpenAI-compatible)
CEREBRAS_API_KEY=
CEREBRAS_MODEL=llama3.1-8b
CEREBRAS_OPENAI_BASE_URL=https://api.cerebras.ai/v1/

# Rough input-token estimate (~4 chars/token). Above this → Gemini when provider=auto.
LLM_LONG_CONTEXT_THRESHOLD_TOKENS=8000

# Legacy providers (optional; used when DEFAULT_LLM_PROVIDER is anthropic or openai)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Auth
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
MAX_PROMPT_CHARS=12000
MAX_TOOL_INPUT_CHARS=6000
RATE_LIMIT_PER_MINUTE=60

# Observability
SENTRY_DSN=

# Optional search
SERPAPI_KEY=

# Agent file tools (must exist on disk; paths are confined under this directory)
AGENT_FILES_ROOT=/tmp/svet_agent_files

# Optional email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@localhost
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=

# Optional Google Calendar
GOOGLE_CALENDAR_ACCESS_TOKEN=
GOOGLE_CALENDAR_ID=primary

# Environment
ENVIRONMENT=dev
CORS_ORIGINS=*
